/**
 * ClientStreamReceiver receives streamed messages from the server
 */
export class ClientStreamReceiver<T> {
  private done = false;

  constructor(
    private readonly sub: any,
    private readonly decoder: (data: Uint8Array) => T
  ) {}

  /**
   * Receive the next message. Returns null on end-of-stream.
   */
  async recv(): Promise<T | null> {
    if (this.done) return null;
    for await (const msg of this.sub) {
      if (msg.headers?.get('Nats-Stream-End') === 'true') {
        const errorCode = msg.headers?.get('Nats-Service-Error-Code') || msg.headers?.get('Status');
        if (errorCode) {
          const desc = msg.headers?.get('Nats-Service-Error') || msg.headers?.get('Description') || 'Stream error';
          throw new Error(`Stream error [${errorCode}]: ${desc}`);
        }
        this.done = true;
        return null;
      }
      return this.decoder(msg.data);
    }
    return null;
  }

  /**
   * Async iterator for receiving streamed messages
   */
  async *[Symbol.asyncIterator](): AsyncIterableIterator<T> {
    while (true) {
      const val = await this.recv();
      if (val === null) break;
      yield val;
    }
  }

  /**
   * Drain all stream chunks into a single Uint8Array.
   * WARNING: entire payload is buffered in memory.
   */
  async recvBytes(field: string = 'data'): Promise<Uint8Array> {
    const chunks: Uint8Array[] = [];
    for await (const msg of this) {
      const chunk = (msg as any)[field];
      if (chunk) chunks.push(chunk);
    }
    const total = chunks.reduce((s, c) => s + c.length, 0);
    const result = new Uint8Array(total);
    let offset = 0;
    for (const c of chunks) {
      result.set(c, offset);
      offset += c.length;
    }
    return result;
  }

  /**
   * Stream chunks to a Node.js WritableStream.
   */
  async recvToWriter(writable: any, field: string = 'data'): Promise<void> {
    for await (const msg of this) {
      const chunk = (msg as any)[field];
      if (chunk) {
        if (typeof writable.write === 'function') {
          await new Promise<void>((resolve, reject) => {
            if (!writable.write(chunk)) {
              writable.once('drain', resolve);
            } else {
              resolve();
            }
          });
        }
      }
    }
  }

  /**
   * Download stream to file atomically (temp file + rename).
   * Requires Node.js fs module.
   */
  async recvToFile(path: string, field: string = 'data'): Promise<void> {
    const fs = await import('fs');
    const os = await import('os');
    const nodePath = await import('path');
    const dir = nodePath.dirname(nodePath.resolve(path));
    const tmpPath = nodePath.join(dir, `.tmp_${Date.now()}_${Math.random().toString(36).slice(2)}`);
    const fd = fs.openSync(tmpPath, 'w');
    try {
      for await (const msg of this) {
        const chunk = (msg as any)[field];
        if (chunk) fs.writeSync(fd, chunk);
      }
      fs.fsyncSync(fd);
      fs.closeSync(fd);
      fs.renameSync(tmpPath, path);
    } catch (err) {
      fs.closeSync(fd);
      try { fs.unlinkSync(tmpPath); } catch {}
      throw err;
    }
  }

  /**
   * Close the stream subscription
   */
  close(): void {
    this.sub.unsubscribe();
  }
}

