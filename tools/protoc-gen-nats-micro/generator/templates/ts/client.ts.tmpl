/**
 * ClientStreamSender sends streamed messages to the server and receives a final response
 */
export class ClientStreamSender<TInput, TOutput> {
  private seq = 0;

  constructor(
    private readonly nc: NatsConnection,
    private readonly serverInbox: string,
    private readonly replyInbox: string,
    private readonly encoder: (msg: TInput) => Uint8Array,
    private readonly decoder: (data: Uint8Array) => TOutput,
  ) {}

  /**
   * Send a message to the server stream
   */
  async send(msg: TInput): Promise<void> {
    this.seq++;
    const data = this.encoder(msg);
    const h = headers();
    h.set('Nats-Stream-Seq', String(this.seq));
    this.nc.publish(this.serverInbox, data, { headers: h });
  }

  /**
   * Close the stream and wait for the server's final response.
   * Subscribes to the reply inbox first to avoid race conditions.
   */
  async closeAndRecv(): Promise<TOutput> {
    // Subscribe to reply inbox BEFORE sending end marker to avoid race
    const sub = this.nc.subscribe(this.replyInbox, { max: 1 });

    // Send end-of-stream marker
    const h = headers();
    h.set('Nats-Stream-End', 'true');
    this.nc.publish(this.serverInbox, new Uint8Array(0), { headers: h });

    // Wait for the final response
    for await (const msg of sub) {
      // Check for error response
      const errorCode = msg.headers?.get('Nats-Service-Error-Code') || msg.headers?.get('Status');
      if (errorCode) {
        const desc = msg.headers?.get('Nats-Service-Error') || msg.headers?.get('Description') || 'Stream error';
        throw new Error(`Stream error [${errorCode}]: ${desc}`);
      }
      return this.decoder(msg.data);
    }

    throw new Error('Client-streaming response not received');
  }
}
