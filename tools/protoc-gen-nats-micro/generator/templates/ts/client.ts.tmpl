/**
 * Chunked stream receiver for {{.GoName}} with download convenience helpers.
 */
export class {{$.Service.GoName}}_{{.GoName}}_ChunkedReceiver extends ClientStreamReceiver<pb.{{.Output.GoIdent.GoName}}> {
  /**
   * recvBytes drains the entire stream into a single Uint8Array.
   * WARNING: the entire payload is accumulated in memory. For large or
   * unbounded streams, iterate the receiver directly instead.
   */
  async recvBytes(): Promise<Uint8Array> {
    const chunks: Uint8Array[] = [];
    let totalLength = 0;
    for await (const msg of this) {
      const chunk = msg.{{ToCamelCase $endpointOpts.ChunkedIO.ChunkField}};
      chunks.push(chunk);
      totalLength += chunk.length;
    }
    const result = new Uint8Array(totalLength);
    let offset = 0;
    for (const chunk of chunks) {
      result.set(chunk, offset);
      offset += chunk.length;
    }
    return result;
  }
}
