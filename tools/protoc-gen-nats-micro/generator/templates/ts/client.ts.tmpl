/**
 * Client-streaming: send multiple {{.Input.GoIdent.GoName}} messages, receive a single {{.Output.GoIdent.GoName}}
 */
export class {{$.Service.GoName}}_{{.GoName}}_ClientStream {
  private seq = 0;
  private recvResolve: ((value: any) => void) | null;

  constructor(
    private readonly nc: NatsConnection,
    private readonly serverInbox: string,
    private readonly sub: any,
    private readonly recvQueue: any[],
    recvResolve: ((value: any) => void) | null,
    private readonly decoder: (data: Uint8Array) => pb.{{.Output.GoIdent.GoName}},
    private readonly encoder: (val: pb.{{.Input.GoIdent.GoName}}) => Uint8Array,
  ) {
    this.recvResolve = recvResolve;
  }

  /** Send a message to the server */
  async send(val: pb.{{.Input.GoIdent.GoName}}): Promise<void> {
    this.seq++;
    const data = this.encoder(val);
    const h = headers();
    h.set('Nats-Stream-Seq', String(this.seq));
    this.nc.publish(this.serverInbox, data, { headers: h });
  }

  {{- if $endpointOpts.ChunkedIO}}

  /** Send a single chunk of bytes */
  async sendBytes(data: Uint8Array): Promise<void> {
    const msg = new pb.{{.Input.GoIdent.GoName}}();
    (msg as any).{{ToLowerFirst (ToCamelCase $endpointOpts.ChunkedIO.ChunkField)}} = data;
    await this.send(msg);
  }

  /** Stream from a ReadableStream in chunks */
  async sendReader(readable: ReadableStream<Uint8Array>, chunkSize: number = {{$endpointOpts.ChunkedIO.DefaultChunkSize}}): Promise<void> {
    const reader = readable.getReader();
    let buffer = new Uint8Array(0);
    try {
      while (true) {
        const { done, value } = await reader.read();
        if (value) {
          const combined = new Uint8Array(buffer.length + value.length);
          combined.set(buffer);
          combined.set(value, buffer.length);
          buffer = combined;
          while (buffer.length >= chunkSize) {
            await this.sendBytes(buffer.slice(0, chunkSize));
            buffer = buffer.slice(chunkSize);
          }
        }
        if (done) break;
      }
      if (buffer.length > 0) {
        await this.sendBytes(buffer);
      }
    } finally {
      reader.releaseLock();
    }
  }

  /** Stream a file in chunks (Node.js only) */
  async sendFile(path: string, chunkSize: number = {{$endpointOpts.ChunkedIO.DefaultChunkSize}}): Promise<void> {
    const fs = await import('fs');
    const fd = fs.openSync(path, 'r');
    const buf = Buffer.alloc(chunkSize);
    try {
      while (true) {
        const n = fs.readSync(fd, buf);
        if (n === 0) break;
        await this.sendBytes(buf.slice(0, n));
      }
    } finally {
      fs.closeSync(fd);
    }
  }
  {{- end}}

  /** Signal end-of-stream and wait for the final response */
  async closeAndRecv(timeout: number = 30000): Promise<pb.{{.Output.GoIdent.GoName}}> {
    const h = headers();
    h.set('Nats-Stream-End', 'true');
    this.nc.publish(this.serverInbox, new Uint8Array(0), { headers: h });

    const raw = this.recvQueue.length > 0
      ? this.recvQueue.shift()
      : await new Promise<any>((resolve) => {
          const timer = setTimeout(() => resolve(null), timeout);
          this.recvResolve = (v) => { clearTimeout(timer); resolve(v); };
        });

    this.sub.unsubscribe();

    if (!raw) throw new Error('Timeout waiting for response');

    const errorCode = raw.headers?.get('Status') || raw.headers?.get('Nats-Service-Error-Code');
    if (errorCode) {
      const desc = raw.headers?.get('Description') || raw.headers?.get('Nats-Service-Error') || '';
      throw new Error(`Stream error [${errorCode}]: ${desc}`);
    }

    return this.decoder(raw.data);
  }

  close(): void {
    this.sub.unsubscribe();
  }
}
{{- end}}
{{- end}}

