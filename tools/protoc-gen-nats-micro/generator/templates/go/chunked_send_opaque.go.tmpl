{{- /* Chunked upload helpers — opaque proto mode.
       SendReader and SendFile are identical to chunked_send.go.tmpl;
       only SendBytes differs (setter vs struct literal). Separate files are
       required because Go build tags (//go:build protoopaque vs !protoopaque)
       must apply to the entire compilation unit. */ -}}
//go:build protoopaque

package {{.File.GoPackageName}}

import (
  "errors"
  "fmt"
  "io"
  "os"
)

{{- range $svc := .File.Services}}
{{- range .Methods}}
{{- $endpointOpts := GetEndpointOptions .}}
{{- if and $endpointOpts.ChunkedIO (IsClientStreaming .) (not (IsServerStreaming .))}}

// SendBytes sends a single payload chunk to the server.
func (s *{{$svc.GoName}}_{{.GoName}}_ClientStream) SendBytes(data []byte) error {
  msg := &{{$.QualifiedGoIdent .Input.GoIdent}}{}
  msg.Set{{$endpointOpts.ChunkedIO.GoFieldName}}(data)
  return s.Send(msg)
}

// SendReader copies r into chunked stream messages.
func (s *{{$svc.GoName}}_{{.GoName}}_ClientStream) SendReader(r io.Reader, chunkSize int) error {
  if chunkSize <= 0 {
    chunkSize = {{$endpointOpts.ChunkedIO.DefaultChunkSize}}
  }

  buf := make([]byte, chunkSize)
  for {
    n, err := r.Read(buf)
    if n > 0 {
      if sendErr := s.SendBytes(buf[:n]); sendErr != nil {
        return sendErr
      }
    }
    if err != nil {
      if errors.Is(err, io.EOF) {
        return nil
      }
      return fmt.Errorf("failed to read chunk: %w", err)
    }
  }
}

// SendFile streams a file to the server in chunked messages.
// On error, some chunks may have already been transmitted; the caller
// should handle partial-send semantics at the application level.
func (s *{{$svc.GoName}}_{{.GoName}}_ClientStream) SendFile(path string, chunkSize int) error {
  f, err := os.Open(path)
  if err != nil {
    return fmt.Errorf("failed to open file: %w", err)
  }
  defer f.Close()

  return s.SendReader(f, chunkSize)
}
{{- end}}
{{- end}}
{{- end}}
