{{- /* Server implementation */ -}}
{{- $serviceName := .Service.GoName -}}
{{- $serviceOptions := .Options -}}

class {{$serviceName}}Handler(Protocol):
    """Handler interface for {{$serviceName}} service"""
    {{- range .Service.Methods}}
    {{- $methodOptions := GetEndpointOptions .}}
    {{- if not $methodOptions.Skip}}
    {{- if IsUnary .}}

    async def {{ToSnakeCase .GoName}}(
        self,
        req: pb.{{.Input.GoIdent.GoName}},
        info: ServerInfo
    ) -> pb.{{.Output.GoIdent.GoName}}:
        """{{.Comments.Leading}}"""
        ...
    {{- else if IsServerStreaming .}}
    {{- if not (IsClientStreaming .)}}

    async def {{ToSnakeCase .GoName}}(
        self,
        req: pb.{{.Input.GoIdent.GoName}},
        stream: "ServerStreamSender",
        info: ServerInfo
    ) -> None:
        """{{.Comments.Leading}} (server-streaming)"""
        ...
    {{- else}}

    async def {{ToSnakeCase .GoName}}(
        self,
        stream: "BidiStream",
        info: ServerInfo
    ) -> None:
        """{{.Comments.Leading}} (bidirectional streaming)"""
        ...
    {{- end}}
    {{- else if IsClientStreaming .}}

    async def {{ToSnakeCase .GoName}}(
        self,
        stream: "ClientStreamReader",
        info: ServerInfo
    ) -> pb.{{.Output.GoIdent.GoName}}:
        """{{.Comments.Leading}} (client-streaming)"""
        ...
    {{- end}}
    {{- if IsClientStreaming .}}
    {{- if not (IsServerStreaming .)}}

    async def {{ToSnakeCase .GoName}}(
        self,
        stream: "AsyncIterator[pb.{{.Input.GoIdent.GoName}}]",
        info: ServerInfo
    ) -> pb.{{.Output.GoIdent.GoName}}:
        """{{.Comments.Leading}} (client-streaming)"""
        ...
    {{- end}}
    {{- end}}
    {{- end}}
    {{- end}}


async def register_{{ToSnakeCase $serviceName}}(
    nc: nats.NATS,
    handler: {{$serviceName}}Handler,
    *opts: RegisterOption
) -> "{{$serviceName}}Wrapper":
    """Register {{$serviceName}} service with NATS micro"""
    
    # Apply default options from proto
    subject_prefix = "{{or $serviceOptions.SubjectPrefix (ToSnakeCase $serviceName)}}"
    service_name = "{{or $serviceOptions.Name (ToSnakeCase $serviceName)}}"
    service_version = "{{or $serviceOptions.Version "0.0.1"}}"
    service_description = "{{or $serviceOptions.Description $serviceName}}"
    {{- if $serviceOptions.Timeout}}
    default_timeout: float = {{$serviceOptions.Timeout.Seconds}}.0
    {{- else}}
    default_timeout: float = 0.0
    {{- end}}
    metadata: Dict[str, str] = {
        {{- range $key, $value := $serviceOptions.Metadata}}
        "{{$key}}": "{{$value}}",
        {{- end}}
    }
    interceptors: List[UnaryServerInterceptor] = []
    js_context: Any = None  # Optional JetStream context
    
    # Apply runtime options
    for opt in opts:
        if isinstance(opt, _WithSubjectPrefix):
            subject_prefix = opt.prefix
        elif isinstance(opt, _WithName):
            service_name = opt.name
        elif isinstance(opt, _WithVersion):
            service_version = opt.version
        elif isinstance(opt, _WithDescription):
            service_description = opt.description
        elif isinstance(opt, _WithTimeout):
            default_timeout = opt.timeout
        elif isinstance(opt, _WithMetadata):
            metadata = opt.metadata
        elif isinstance(opt, _WithAdditionalMetadata):
            metadata = {**metadata, **opt.metadata}
        elif isinstance(opt, _WithServerInterceptor):
            interceptors.append(opt.interceptor)
        elif isinstance(opt, _WithJetStream):
            js_context = opt.js
    
    # Chain interceptors
    chain = chain_server_interceptors(interceptors)
    
    # Service configuration
    config = micro.ServiceConfig(
        name=service_name,
        version=service_version,
        description=service_description,
        metadata=metadata if metadata else None
    )
    
    # Create service
    service = await micro.add_service(nc, config)
    
    # Auto-create KV and Object Store buckets if JetStream is available
    if js_context is not None:
        pass  # auto-create buckets below if configured
        {{- range .Service.Methods}}
        {{- $eopts := GetEndpointOptions .}}
        {{- if $eopts.KVStore}}
        # Auto-create KV bucket "{{$eopts.KVStore.Bucket}}" for {{.GoName}}
        try:
            await js_context.create_key_value(nats.js.api.KeyValueConfig(
                bucket="{{$eopts.KVStore.Bucket}}",
                {{- if $eopts.KVStore.Description}}
                description="{{$eopts.KVStore.Description}}",
                {{- end}}
                {{- if $eopts.KVStore.MaxHistory}}
                history={{$eopts.KVStore.MaxHistory}},
                {{- end}}
                {{- if $eopts.KVStore.TTL.Nanoseconds}}
                ttl={{$eopts.KVStore.TTL.Seconds}},
                {{- end}}
                {{- if $eopts.KVStore.Metadata}}
                # Requires nats-py >= 2.15 (metadata support)
                metadata={ {{- range $key, $value := $eopts.KVStore.Metadata}}"{{$key}}": "{{$value}}", {{end}} },
                {{- end}}
                {{- if $eopts.KVStore.Compression}}
                # Requires nats-py >= 2.15 (compression support)
                compression=True,
                {{- end}}
            ))
        except Exception as e:
            logging.warning(f"[nats-micro] WARN: failed to create KV bucket '{{$eopts.KVStore.Bucket}}': {e}")
        {{- end}}
        {{- if $eopts.ObjectStore}}
        # Auto-create Object Store bucket "{{$eopts.ObjectStore.Bucket}}" for {{.GoName}}
        try:
            await js_context.create_object_store(nats.js.api.ObjectStoreConfig(
                bucket="{{$eopts.ObjectStore.Bucket}}",
                {{- if $eopts.ObjectStore.Description}}
                description="{{$eopts.ObjectStore.Description}}",
                {{- end}}
                {{- if $eopts.ObjectStore.TTL.Nanoseconds}}
                ttl={{$eopts.ObjectStore.TTL.Seconds}},
                {{- end}}
                {{- if $eopts.ObjectStore.Compression}}
                # Requires nats-py >= 2.15 (compression support)
                compression=True,
                {{- end}}
            ))
        except Exception as e:
            logging.warning(f"[nats-micro] WARN: failed to create Object Store bucket '{{$eopts.ObjectStore.Bucket}}': {e}")
        {{- end}}
        {{- end}}
    
    {{- range .Service.Methods}}
    {{- $methodOptions := GetEndpointOptions .}}
    {{- if not $methodOptions.Skip}}
    {{- if IsUnary .}}
    
    # Register {{.GoName}} endpoint (unary)
    async def _handle_{{ToSnakeCase .GoName}}(req: micro.Request) -> None:
        try:
            # Parse request
            {{- if $serviceOptions.UseJSON}}
            request_msg = Parse(req.data.decode(), pb.{{.Input.GoIdent.GoName}}())
            {{- else}}
            request_msg = pb.{{.Input.GoIdent.GoName}}.FromString(req.data)
            {{- end}}
            
            # Extract headers
            headers: Dict[str, str] = {}
            if req.headers:
                for key, values in req.headers.items():
                    if values:
                        headers[key] = values[0] if isinstance(values, list) else values
            
            # Create server info with service context
            info = ServerInfo(
                service="{{$serviceName}}",
                method="{{.GoName}}",
                subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
                headers=headers
            )
            
            # Create handler wrapper
            async def invoke(
                req_inner: pb.{{.Input.GoIdent.GoName}},
                info_inner: ServerInfo
            ) -> pb.{{.Output.GoIdent.GoName}}:
                {{- if or (gt $methodOptions.Timeout.Nanoseconds 0) true}}
                # Apply timeout if configured
                effective_timeout = {{if gt $methodOptions.Timeout.Nanoseconds 0}}{{$methodOptions.Timeout.Seconds}}.0{{else}}default_timeout{{end}}
                if effective_timeout > 0:
                    return await asyncio.wait_for(
                        handler.{{ToSnakeCase .GoName}}(req_inner, info_inner),
                        timeout=effective_timeout
                    )
                {{- end}}
                return await handler.{{ToSnakeCase .GoName}}(req_inner, info_inner)
            
            # Execute with interceptors
            if chain:
                response_msg = await chain(request_msg, info, invoke)
            else:
                response_msg = await invoke(request_msg, info)
            
            # Serialize response
            {{- if $serviceOptions.UseJSON}}
            response_data = MessageToJson(response_msg).encode()
            {{- else}}
            response_data = response_msg.SerializeToString()
            {{- end}}
            
            {{- /* KV Store persistence */}}
            {{- if $methodOptions.KVStore}}
            {{- if not $methodOptions.KVStore.ClientOnly}}
            # Auto-persist response to KV Store (bucket: "{{$methodOptions.KVStore.Bucket}}")
            {{- if IsKVPersistFailureRequired $methodOptions.KVStore}}
            if js_context is None:
                error_headers = {"Status": ERROR_CODE_INTERNAL, "Description": "KV persistence requires JetStream"}
                await req.respond(b'', headers=error_headers)
                return
            {{- end}}
            if js_context is not None:
                try:
                    kv_key = {{ResolveKeyTemplatePy $methodOptions.KVStore.KeyTemplate .}}
                    kv = await js_context.key_value("{{$methodOptions.KVStore.Bucket}}")
                    {{- if IsKVWriteModeCompareAndSet $methodOptions.KVStore}}
                    # Compare-and-set: create or update with revision check
                    try:
                        await kv.create(kv_key, response_data)
                    except Exception:
                        entry = await kv.get(kv_key)
                        await kv.update(kv_key, response_data, last=entry.revision)
                    {{- else if IsKVWriteModeCreateOnly $methodOptions.KVStore}}
                    # Create-only: fail if key already exists
                    await kv.create(kv_key, response_data)
                    {{- else}}
                    # Last-write-wins (default)
                    await kv.put(kv_key, response_data)
                    {{- end}}
                except Exception as kv_err:
                    {{- if IsKVPersistFailureRequired $methodOptions.KVStore}}
                    error_headers = {"Status": ERROR_CODE_INTERNAL, "Description": f"failed to persist {{.GoName}} response to KV: {kv_err}"}
                    await req.respond(b'', headers=error_headers)
                    return
                    {{- else}}
                    logging.warning(f"[nats-micro] KV persist failed for {{.GoName}}: {kv_err}")
                    {{- end}}
            {{- end}}
            {{- end}}
            
            {{- /* Object Store persistence */}}
            {{- if $methodOptions.ObjectStore}}
            {{- if not $methodOptions.ObjectStore.ClientOnly}}
            # Auto-persist response to Object Store (bucket: "{{$methodOptions.ObjectStore.Bucket}}")
            if js_context is not None:
                try:
                    obj_key = {{ResolveKeyTemplatePy $methodOptions.ObjectStore.KeyTemplate .}}
                    obj = await js_context.object_store("{{$methodOptions.ObjectStore.Bucket}}")
                    await obj.put(obj_key, response_data)
                except Exception as obj_err:
                    import logging
                    logging.warning(f"[nats-micro] Object Store persist failed for {{.GoName}}: {obj_err}")
            {{- end}}
            {{- end}}
            
            # Add response headers from handler/interceptors
            resp_headers = None
            if info.response_headers:
                resp_headers = info.response_headers
            
            # Send response
            await req.respond(response_data, headers=resp_headers)
            
        except asyncio.TimeoutError:
            # Timeout error - use standard NATS micro error headers
            error_headers = {
                "Status": ERROR_CODE_INTERNAL,
                "Description": "request timeout for {{.GoName}}"
            }
            await req.respond(b'', headers=error_headers)
            
        except {{$serviceName}}Error as e:
            # Service error - use standard NATS micro error headers
            error_headers = {
                "Status": e.code,
                "Description": e.message
            }
            await req.respond(e.data or b'', headers=error_headers)
            
        except Exception as e:
            # Unexpected error - use standard NATS micro error headers
            error_headers = {
                "Status": ERROR_CODE_INTERNAL,
                "Description": str(e)
            }
            await req.respond(b'', headers=error_headers)
    
    # Add endpoint
    await service.add_endpoint(
        name="{{.GoName}}",
        handler=_handle_{{ToSnakeCase .GoName}},
        subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
        {{- if $methodOptions.Metadata}}
        metadata={
            {{- range $key, $value := $methodOptions.Metadata}}
            "{{$key}}": "{{$value}}",
            {{- end}}
        }
        {{- end}}
    )
    {{- end}}{{/* end IsUnary */}}

    {{- if IsServerStreaming .}}
    {{- if not (IsClientStreaming .)}}

    # Register {{.GoName}} endpoint (server-streaming)
    async def _handle_{{ToSnakeCase .GoName}}(req: micro.Request) -> None:
        try:
            # Parse request
            {{- if $serviceOptions.UseJSON}}
            request_msg = Parse(req.data.decode(), pb.{{.Input.GoIdent.GoName}}())
            {{- else}}
            request_msg = pb.{{.Input.GoIdent.GoName}}.FromString(req.data)
            {{- end}}

            headers_dict: Dict[str, str] = {}
            if req.headers:
                for key, values in req.headers.items():
                    if values:
                        headers_dict[key] = values[0] if isinstance(values, list) else values

            reply_subject = headers_dict.get("Reply-To", "")
            if not reply_subject:
                raise ValueError("No Reply-To header for streaming response")

            info = ServerInfo(
                service="{{$serviceName}}",
                method="{{.GoName}}",
                subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
                headers=headers_dict
            )

            sender = ServerStreamSender(nc, reply_subject)
            await handler.{{ToSnakeCase .GoName}}(request_msg, sender, info)
            await sender.close()

        except Exception as e:
            logging.error(f"[nats-micro] ERROR: {{.GoName}} stream handler failed: {e}")

    await service.add_endpoint(
        name="{{.GoName}}",
        handler=_handle_{{ToSnakeCase .GoName}},
        subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
    )
    {{- else}}{{/* bidi-streaming */}}

    # Register {{.GoName}} endpoint (bidirectional streaming)
    async def _handle_{{ToSnakeCase .GoName}}(req: micro.Request) -> None:
        try:
            headers_dict: Dict[str, str] = {}
            if req.headers:
                for key, values in req.headers.items():
                    if values:
                        headers_dict[key] = values[0] if isinstance(values, list) else values

            client_inbox = headers_dict.get("Reply-To", "")
            if not client_inbox:
                raise ValueError("No Reply-To header for bidi streaming")

            # Create server inbox for receiving client messages
            server_inbox = nc.new_inbox()
            recv_queue: asyncio.Queue = asyncio.Queue(maxsize=64)
            sub = await nc.subscribe(server_inbox, cb=lambda msg: recv_queue.put_nowait(msg))

            # Ack with server inbox so client knows where to send
            await nc.publish(client_inbox, b'', headers={NATS_STREAM_INBOX_HEADER: server_inbox})

            info = ServerInfo(
                service="{{$serviceName}}",
                method="{{.GoName}}",
                subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
                headers=headers_dict
            )

            sender = ServerStreamSender(nc, client_inbox)
            {{- if $serviceOptions.UseJSON}}
            reader = ClientStreamReader(recv_queue, pb.{{.Input.GoIdent.GoName}}, use_json=True)
            {{- else}}
            reader = ClientStreamReader(recv_queue, pb.{{.Input.GoIdent.GoName}}, use_json=False)
            {{- end}}
            stream = BidiStream(sender, reader)

            try:
                await handler.{{ToSnakeCase .GoName}}(stream, info)
            finally:
                await sender.close()
                await sub.unsubscribe()

        except Exception as e:
            logging.error(f"[nats-micro] ERROR: {{.GoName}} bidi stream handler failed: {e}")

    await service.add_endpoint(
        name="{{.GoName}}",
        handler=_handle_{{ToSnakeCase .GoName}},
        subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
    )
    {{- end}}
    {{- end}}

    {{- if IsClientStreaming .}}
    {{- if not (IsServerStreaming .)}}

    # Register {{.GoName}} endpoint (client-streaming)
    async def _handle_{{ToSnakeCase .GoName}}(req: micro.Request) -> None:
        try:
            headers_dict: Dict[str, str] = {}
            if req.headers:
                for key, values in req.headers.items():
                    if values:
                        headers_dict[key] = values[0] if isinstance(values, list) else values

            client_inbox = headers_dict.get("Reply-To", "")
            if not client_inbox:
                raise ValueError("No Reply-To header for client streaming")

            # Create server inbox for receiving client messages
            server_inbox = nc.new_inbox()
            recv_queue: asyncio.Queue = asyncio.Queue(maxsize=64)
            sub = await nc.subscribe(server_inbox, cb=lambda msg: recv_queue.put_nowait(msg))

            # Ack with server inbox so client knows where to send
            await nc.publish(client_inbox, b'', headers={NATS_STREAM_INBOX_HEADER: server_inbox})

            info = ServerInfo(
                service="{{$serviceName}}",
                method="{{.GoName}}",
                subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
                headers=headers_dict
            )

            {{- if $serviceOptions.UseJSON}}
            reader = ClientStreamReader(recv_queue, pb.{{.Input.GoIdent.GoName}}, use_json=True)
            {{- else}}
            reader = ClientStreamReader(recv_queue, pb.{{.Input.GoIdent.GoName}}, use_json=False)
            {{- end}}

            try:
                response_msg = await handler.{{ToSnakeCase .GoName}}(reader, info)
            finally:
                await sub.unsubscribe()

            # Send response back to client
            {{- if $serviceOptions.UseJSON}}
            response_data = MessageToJson(response_msg).encode()
            {{- else}}
            response_data = response_msg.SerializeToString()
            {{- end}}
            await nc.publish(client_inbox, response_data, headers={NATS_STREAM_END_HEADER: "true"})

        except Exception as e:
            logging.error(f"[nats-micro] ERROR: {{.GoName}} client-stream handler failed: {e}")
            if client_inbox:
                await nc.publish(client_inbox, b'', headers={
                    NATS_STREAM_END_HEADER: "true",
                    "Status": ERROR_CODE_INTERNAL,
                    "Description": str(e)
                })

    await service.add_endpoint(
        name="{{.GoName}}",
        handler=_handle_{{ToSnakeCase .GoName}},
        subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
    )
    {{- end}}
    {{- end}}

    {{- if IsClientStreaming .}}
    {{- if not (IsServerStreaming .)}}

    # Register {{.GoName}} endpoint (client-streaming)
    async def _handle_{{ToSnakeCase .GoName}}(req: micro.Request) -> None:
        reply_subject = ""
        try:
            # Extract headers
            headers_dict: Dict[str, str] = {}
            if req.headers:
                for key, values in req.headers.items():
                    if values:
                        headers_dict[key] = values[0] if isinstance(values, list) else values

            reply_subject = headers_dict.get("Reply-To", "")
            if not reply_subject:
                raise ValueError("No Reply-To header for client-streaming response")

            # Create server inbox for receiving client stream messages
            server_inbox = nc.new_inbox()
            sub = await nc.subscribe(server_inbox)

            # Send ack with server inbox
            await req.respond(b'', headers={"Nats-Stream-Inbox": server_inbox})

            # Create async generator for the stream
            async def stream_iter():
                try:
                    while True:
                        try:
                            msg = await sub.next_msg(timeout=30.0)
                        except Exception:
                            break

                        # Check for end-of-stream
                        if msg.headers:
                            end = msg.headers.get("Nats-Stream-End")
                            if end and (end == "true" or (isinstance(end, list) and end[0] == "true")):
                                break

                        # Parse message
                        {{- if $serviceOptions.UseJSON}}
                        yield Parse(msg.data.decode(), pb.{{.Input.GoIdent.GoName}}())
                        {{- else}}
                        yield pb.{{.Input.GoIdent.GoName}}.FromString(msg.data)
                        {{- end}}
                finally:
                    await sub.unsubscribe()

            info = ServerInfo(
                service="{{$serviceName}}",
                method="{{.GoName}}",
                subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
                headers=headers_dict
            )

            # Call handler with stream iterator
            response = await handler.{{ToSnakeCase .GoName}}(stream_iter(), info)

            # Serialize and publish response to reply subject
            {{- if $serviceOptions.UseJSON}}
            response_data = MessageToJson(response).encode()
            {{- else}}
            response_data = response.SerializeToString()
            {{- end}}
            await nc.publish(reply_subject, response_data)

        except Exception as e:
            logging.error(f"[nats-micro] ERROR: {{.GoName}} client stream handler failed: {e}")
            # Try to send error to client
            if reply_subject:
                try:
                    await nc.publish(
                        reply_subject,
                        b'',
                        headers={
                            "Nats-Service-Error-Code": ERROR_CODE_INTERNAL,
                            "Nats-Service-Error": str(e)
                        }
                    )
                except Exception:
                    pass

    await service.add_endpoint(
        name="{{.GoName}}",
        handler=_handle_{{ToSnakeCase .GoName}},
        subject=f"{subject_prefix}.{{ToSnakeCase .GoName}}",
    )
    {{- end}}
    {{- end}}

    {{- end}}
    {{- end}}
    
    return {{$serviceName}}Wrapper(service, subject_prefix)


# Stream protocol header constants
NATS_STREAM_SEQ_HEADER = "Nats-Stream-Seq"
NATS_STREAM_END_HEADER = "Nats-Stream-End"
NATS_STREAM_INBOX_HEADER = "Nats-Stream-Inbox"


class ServerStreamSender:
    """Server-to-client stream sender"""

    def __init__(self, nc: nats.NATS, reply_subject: str):
        self._nc = nc
        self._reply_subject = reply_subject
        self._seq = 0
        self._closed = False

    async def send(self, data: bytes) -> None:
        """Send raw bytes to the client"""
        if self._closed:
            raise RuntimeError("Stream is closed")
        self._seq += 1
        await self._nc.publish(
            self._reply_subject,
            data,
            headers={NATS_STREAM_SEQ_HEADER: str(self._seq)}
        )

    async def send_msg(self, msg: Any, use_json: bool = False) -> None:
        """Serialize and send a protobuf message"""
        if use_json:
            from google.protobuf.json_format import MessageToJson
            data = MessageToJson(msg).encode()
        else:
            data = msg.SerializeToString()
        await self.send(data)

    async def close(self) -> None:
        """Send end-of-stream marker"""
        if self._closed:
            return
        self._closed = True
        await self._nc.publish(
            self._reply_subject,
            b'',
            headers={NATS_STREAM_END_HEADER: "true"}
        )

    async def close_with_error(self, code: str, message: str) -> None:
        """Send error and close"""
        if self._closed:
            return
        self._closed = True
        await self._nc.publish(
            self._reply_subject,
            b'',
            headers={
                NATS_STREAM_END_HEADER: "true",
                "Status": code,
                "Description": message
            }
        )


class ClientStreamReader:
    """Server-side reader for client-streaming messages"""

    def __init__(self, queue: asyncio.Queue, msg_type: Any, use_json: bool = False):
        self._queue = queue
        self._msg_type = msg_type
        self._use_json = use_json
        self._done = False

    async def recv(self, timeout: float = 30.0) -> Any:
        """Receive the next message from the client stream.
        Raises StopAsyncIteration on end-of-stream."""
        if self._done:
            raise StopAsyncIteration
        try:
            raw_msg = await asyncio.wait_for(self._queue.get(), timeout=timeout)
        except asyncio.TimeoutError:
            raise

        # Check for end-of-stream
        if raw_msg.headers and raw_msg.headers.get(NATS_STREAM_END_HEADER) == "true":
            self._done = True
            # Check for error
            status = raw_msg.headers.get("Status", "") or raw_msg.headers.get("Nats-Service-Error-Code", "")
            if status:
                desc = raw_msg.headers.get("Description", "") or raw_msg.headers.get("Nats-Service-Error", "")
                raise RuntimeError(f"Stream error {status}: {desc}")
            raise StopAsyncIteration

        # Deserialize
        if self._use_json:
            from google.protobuf.json_format import Parse
            return Parse(raw_msg.data.decode(), self._msg_type())
        else:
            return self._msg_type.FromString(raw_msg.data)

    def __aiter__(self):
        return self

    async def __anext__(self) -> Any:
        try:
            return await self.recv()
        except StopAsyncIteration:
            raise


class BidiStream:
    """Bidirectional stream combining sender and reader"""

    def __init__(self, sender: ServerStreamSender, reader: ClientStreamReader):
        self.sender = sender
        self.reader = reader

    async def send(self, data: bytes) -> None:
        await self.sender.send(data)

    async def send_msg(self, msg: Any, use_json: bool = False) -> None:
        await self.sender.send_msg(msg, use_json)

    async def recv(self, timeout: float = 30.0) -> Any:
        return await self.reader.recv(timeout)

    async def close_send(self) -> None:
        await self.sender.close()

    def __aiter__(self):
        return self.reader.__aiter__()


class {{$serviceName}}Wrapper:
    """Wrapper around the NATS micro service for {{$serviceName}}"""
    
    def __init__(self, service: micro.Service, subject_prefix: str):
        self._service = service
        self._subject_prefix = subject_prefix
    
    def endpoints(self) -> List[EndpointInfo]:
        """Get list of endpoint info for {{$serviceName}}"""
        return [
            {{- range .Service.Methods}}
            {{- $methodOptions := GetEndpointOptions .}}
            {{- if not $methodOptions.Skip}}
            EndpointInfo(name="{{.GoName}}", subject=f"{self._subject_prefix}.{{ToSnakeCase .GoName}}"),
            {{- end}}
            {{- end}}
        ]
    
    async def stop(self) -> None:
        """Stop the service"""
        await self._service.stop()
    
    def info(self):
        """Get service info"""
        return self._service.info()
