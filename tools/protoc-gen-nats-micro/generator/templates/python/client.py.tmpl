class {{$serviceName}}_{{.GoName}}_ClientStream:
    """Client-streaming: send multiple messages, receive a single response"""

    def __init__(self, nc, server_inbox: str, sub, recv_queue, resp_class, use_json: bool):
        self._nc = nc
        self._server_inbox = server_inbox
        self._sub = sub
        self._recv_queue = recv_queue
        self._resp_class = resp_class
        self._use_json = use_json
        self._seq = 0

    async def send(self, msg) -> None:
        """Send a message to the server"""
        if self._use_json:
            from google.protobuf.json_format import MessageToJson
            data = MessageToJson(msg).encode()
        else:
            data = msg.SerializeToString()
        self._seq += 1
        await self._nc.publish(
            self._server_inbox, data,
            headers={"Nats-Stream-Seq": str(self._seq)}
        )

    {{- if $methodOptions.ChunkedIO}}

    async def send_bytes(self, data: bytes) -> None:
        """Send a single chunk of bytes"""
        msg = pb.{{.Input.GoIdent.GoName}}()
        setattr(msg, "{{$methodOptions.ChunkedIO.ChunkField}}", data)
        await self.send(msg)

    async def send_reader(self, reader, chunk_size: int = 0) -> None:
        """Stream from a file-like readable in chunks"""
        if chunk_size <= 0:
            chunk_size = {{$methodOptions.ChunkedIO.DefaultChunkSize}}
        while True:
            chunk = reader.read(chunk_size)
            if not chunk:
                break
            await self.send_bytes(chunk)

    async def send_file(self, path: str, chunk_size: int = 0) -> None:
        """Stream a file in chunks"""
        with open(path, 'rb') as f:
            await self.send_reader(f, chunk_size)
    {{- end}}

    async def close_and_recv(self, timeout: float = 30.0):
        """Signal end-of-stream and wait for the final response"""
        await self._nc.publish(
            self._server_inbox, b'',
            headers={"Nats-Stream-End": "true"}
        )
        try:
            raw_msg = await asyncio.wait_for(self._recv_queue.get(), timeout=timeout)
        except asyncio.TimeoutError:
            await self._sub.unsubscribe()
            raise
        await self._sub.unsubscribe()

        # Check for error
        if raw_msg.headers:
            status = raw_msg.headers.get("Status") or raw_msg.headers.get("Nats-Service-Error-Code")
            if status:
                status_str = status[0] if isinstance(status, list) else status
                desc = raw_msg.headers.get("Description") or raw_msg.headers.get("Nats-Service-Error", "")
                desc_str = desc[0] if isinstance(desc, list) else desc
                raise RuntimeError(f"Stream error [{status_str}]: {desc_str}")

        if self._use_json:
            from google.protobuf.json_format import Parse
            return Parse(raw_msg.data.decode(), self._resp_class())
        else:
            return self._resp_class.FromString(raw_msg.data)

    async def close(self):
        await self._sub.unsubscribe()
{{- end}}
{{- end}}

{{- if IsBidiStreaming .}}

class {{$serviceName}}_{{.GoName}}_BidiStream:
    """Bidirectional streaming: send and receive messages concurrently"""

    def __init__(self, nc, server_inbox: str, sub, recv_queue, resp_class, use_json: bool):
        self._nc = nc
        self._server_inbox = server_inbox
        self._sub = sub
        self._recv_queue = recv_queue
        self._resp_class = resp_class
        self._use_json = use_json
        self._seq = 0
        self._recv_done = False

    async def send(self, msg) -> None:
        """Send a message to the server"""
        if self._use_json:
            from google.protobuf.json_format import MessageToJson
            data = MessageToJson(msg).encode()
        else:
            data = msg.SerializeToString()
        self._seq += 1
        await self._nc.publish(
            self._server_inbox, data,
            headers={"Nats-Stream-Seq": str(self._seq)}
        )

    async def recv(self, timeout: float = 30.0):
        """Receive the next message from the server. Raises StopAsyncIteration on end."""
        if self._recv_done:
            raise StopAsyncIteration
        try:
            raw_msg = await asyncio.wait_for(self._recv_queue.get(), timeout=timeout)
        except asyncio.TimeoutError:
            raise

        if raw_msg.headers:
            end = raw_msg.headers.get("Nats-Stream-End")
            if end and (end == "true" or (isinstance(end, list) and end[0] == "true")):
                self._recv_done = True
                status = raw_msg.headers.get("Status") or raw_msg.headers.get("Nats-Service-Error-Code")
                if status:
                    status_str = status[0] if isinstance(status, list) else status
                    desc = raw_msg.headers.get("Description") or raw_msg.headers.get("Nats-Service-Error", "")
                    desc_str = desc[0] if isinstance(desc, list) else desc
                    raise RuntimeError(f"Stream error [{status_str}]: {desc_str}")
                raise StopAsyncIteration

        if self._use_json:
            from google.protobuf.json_format import Parse
            return Parse(raw_msg.data.decode(), self._resp_class())
        else:
            return self._resp_class.FromString(raw_msg.data)

    async def close_send(self) -> None:
        """Signal that the client is done sending"""
        await self._nc.publish(
            self._server_inbox, b'',
            headers={"Nats-Stream-End": "true"}
        )

    async def close(self) -> None:
        """Close the stream entirely"""
        await self._sub.unsubscribe()

    def __aiter__(self):
        return self

    async def __anext__(self):
        return await self.recv()
{{- end}}
{{- end}}
{{- end}}
