{{- $methodOptions := GetEndpointOptions .}}
{{- if not $methodOptions.Skip}}
{{- if IsClientStreaming .}}
{{- if not (IsServerStreaming .)}}
{{- if $methodOptions.ChunkedIO}}

class ChunkedClientStreamSender(ClientStreamSender):
    """Client-streaming sender with chunked upload helper for {{.GoName}}"""

    async def send_bytes(self, data: bytes) -> None:
        """Create a chunk message with the given bytes and send it"""
        msg = self._msg_class()
        msg.{{$methodOptions.ChunkedIO.ChunkField}} = data
        await self.send(msg)
{{- end}}
{{- end}}
{{- end}}
{{- end}}
{{- end}}
